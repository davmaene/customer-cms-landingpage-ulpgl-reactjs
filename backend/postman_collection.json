    {
      "name": "Contents (Articles, Events, Activities)",
      "item": [
        {
          "name": "List published contents",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/contents?type=article&limit=50&facultyId={{faculty_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "contents"],
              "query": [
                { "key": "type", "value": "article", "description": "article | event | activity (optionnel)" },
                { "key": "limit", "value": "50" },
                { "key": "facultyId", "value": "{{faculty_id}}", "description": "Filtrer par faculté (optionnel)" },
                { "key": "status", "value": "published", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get content by slug",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/contents/slug/celebration-de-la-journee-internationale-du-travail-a-lulpgl-goma",
              "host": ["{{base_url}}"],
              "path": ["api", "contents", "slug", "celebration-de-la-journee-internationale-du-travail-a-lulpgl-goma"]
            }
          }
        },
        {
          "name": "Admin list (own contents if publisher, all if admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/contents/admin?status=pending",
              "host": ["{{base_url}}"],
              "path": ["api", "contents", "admin"],
              "query": [{ "key": "status", "value": "pending", "description": "pending | published | rejected (optionnel)" }]
            }
          }
        },
        {
          "name": "Create content",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('content_id', pm.response.json().item.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"article\",\n  \"title\": \"Mon nouvel article\",\n  \"excerpt\": \"Résumé court\",\n  \"content\": \"<p>Contenu HTML complet de l'article.</p>\",\n  \"category\": \"Académique\",\n  \"coverImage\": \"https://example.com/cover.jpg\",\n  \"eventDate\": null,\n  \"location\": null\n}"
            },
            "url": { "raw": "{{base_url}}/api/contents", "host": ["{{base_url}}"], "path": ["api", "contents"] },
            "description": "**Publisher** → status=pending\n**Admin** → status=published\n\n`type` ∈ ['article', 'event', 'activity'].\nPour event : `eventDate` (ISO datetime) et `location` sont utilisés."
          }
        },
        {
          "name": "Update content",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Titre mis à jour\",\n  \"excerpt\": \"Nouveau résumé\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/contents/{{content_id}}", "host": ["{{base_url}}"], "path": ["api", "contents", "{{content_id}}"] }
          }
        },
        {
          "name": "Approve content (Admin)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/contents/{{content_id}}/approve", "host": ["{{base_url}}"], "path": ["api", "contents", "{{content_id}}", "approve"] }
          }
        },
        {
          "name": "Reject content (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Contenu non conforme\"\n}" },
            "url": { "raw": "{{base_url}}/api/contents/{{content_id}}/reject", "host": ["{{base_url}}"], "path": ["api", "contents", "{{content_id}}", "reject"] }
          }
        },
        {
          "name": "Delete content",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/api/contents/{{content_id}}", "host": ["{{base_url}}"], "path": ["api", "contents", "{{content_id}}"] }
          }
        }
      ]
    },
